#!/usr/bin/env bash
set -euo pipefail

FLUTTER="${FLUTTER:-/home/niklas/flutter/bin/flutter}"
export ANDROID_HOME="${ANDROID_HOME:-$HOME/android-sdk}"
export ANDROID_SDK_ROOT="$ANDROID_HOME"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
OUT_DIR="$SCRIPT_DIR/.build"
KEY_PROPS="$SCRIPT_DIR/android/key.properties"
KEYSTORE="$SCRIPT_DIR/android/tjena-dev.keystore"
APK_SRC="$SCRIPT_DIR/build/app/outputs/flutter-apk/app-release.apk"

mkdir -p "$OUT_DIR"

# Auto-generate a development signing keystore if none configured yet
if [ ! -f "$KEY_PROPS" ]; then
  echo "==> No key.properties found — generating development keystore..."
  keytool -genkey -v \
    -keystore "$KEYSTORE" \
    -alias tjena \
    -keyalg RSA -keysize 2048 -validity 10000 \
    -dname "CN=Tjena Dev, OU=Dev, O=Tjena, L=Unknown, ST=Unknown, C=SE" \
    -storepass tjena123 -keypass tjena123 \
    -noprompt 2>/dev/null
  cat > "$KEY_PROPS" <<EOF
keyAlias=tjena
keyPassword=tjena123
storeFile=$KEYSTORE
storePassword=tjena123
EOF
  echo "==> Development keystore created at $KEYSTORE"
fi

# Apply the matrix-dart-sdk VoIP fix (remote video on Android). Idempotent;
# re-applied here so it survives `flutter pub get` regenerating the dependency.
# The matrix package is a *git* dependency, so we resolve its real source path
# from .dart_tool/package_config.json rather than guessing pub-cache layout.
# See patches/voip_remote_stream_fix.py for details.
echo "==> Ensuring matrix SDK VoIP patch is applied..."
CALL_SESSION="$(python3 - "$SCRIPT_DIR" <<'PY'
import json, os, sys
from urllib.parse import urlparse, unquote
root = sys.argv[1]
cfg = os.path.join(root, ".dart_tool", "package_config.json")
try:
    data = json.load(open(cfg))
except Exception:
    sys.exit(0)
for p in data.get("packages", []):
    if p.get("name") == "matrix":
        uri = p.get("rootUri", "")
        if uri.startswith("file://"):
            base = unquote(urlparse(uri).path)
        else:
            # relative to the .dart_tool directory
            base = os.path.normpath(os.path.join(root, ".dart_tool", uri))
        print(os.path.join(base, "lib", "src", "voip", "call_session.dart"))
        break
PY
)"
if [ -n "$CALL_SESSION" ] && [ -f "$CALL_SESSION" ]; then
  echo "  matrix source: $CALL_SESSION"
  # Restore to pristine first so the patch always applies to a clean file
  # (avoids layering a new patch version on top of an older one). The matrix
  # dep is a git checkout, so this is safe; ignore errors if it isn't.
  MATRIX_REPO="$(dirname "$(dirname "$(dirname "$(dirname "$(dirname "$CALL_SESSION")")")")")"
  git -C "$MATRIX_REPO" checkout -- lib/src/voip/call_session.dart 2>/dev/null || true
  python3 "$SCRIPT_DIR/patches/voip_remote_stream_fix.py" "$CALL_SESSION"
else
  echo "  WARNING: matrix SDK source not found (run 'flutter pub get'); skipping VoIP patch"
fi

echo "==> Building Android APK (release)..."
"$FLUTTER" build apk --release

cp "$APK_SRC" "$OUT_DIR/tjena-release.apk"
echo "==> APK ready: $OUT_DIR/tjena-release.apk"

# Auto-install if a device is connected
ADB="${ANDROID_HOME}/platform-tools/adb"
if "$ADB" devices | grep -q "device$"; then
  echo "==> Device found — installing..."
  "$ADB" install -r "$OUT_DIR/tjena-release.apk" && echo "==> Installed successfully" || {
    echo "==> Direct install failed (likely signature conflict). Reinstalling fresh..."
    "$ADB" uninstall tjena.tjenachat 2>/dev/null || true
    "$ADB" install "$OUT_DIR/tjena-release.apk" && echo "==> Installed successfully"
  }
fi
