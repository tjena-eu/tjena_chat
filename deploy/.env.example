# Copy to .env and fill in. Used by deploy/docker-compose.yml.

# --- Synapse / homeserver ---
# Internal admin+client base reachable from the provisioner container.
#   host Synapse:    http://host.docker.internal:8008
#   compose Synapse: http://synapse:8008  (attach the shared network, see compose)
SYNAPSE_BASE_URL=http://host.docker.internal:8008
# Public homeserver URL the guest's browser uses.
PUBLIC_HS_URL=https://matrix.tjena.eu

# --- Public web ---
# Where this call web client is served (used to build the link).
PUBLIC_WEB_BASE=https://call.tjena.eu
# Host port your Cloudflare Tunnel points at (-> container :80).
WEB_PORT=8080

# --- Secrets (keep private!) ---
# Access token of the @callbot admin service account.
ADMIN_TOKEN=syt_xxx_changeme
# Must equal registration_shared_secret in homeserver.yaml.
REGISTRATION_SHARED_SECRET=changeme_long_random

# --- Tuning ---
CALL_TTL_MINUTES=30
# PROVISIONER_URL=http://provisioner:8090   # only if you relocate the backend
